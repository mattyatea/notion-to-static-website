# サイト名
SITE_NAME="Notion To Static Page"

# サイトの公開URL（末尾スラッシュなし）
# sitemap.xml や robots.txt の生成に使われます
# GA4 / Google Search Console に登録するドメインと一致させてください
PUBLIC_SITE_URL=https://your-site.example.com

# NotionのAPIキー
# Notionインテグレーションの設定画面から取得できます
# https://www.notion.so/my-integrations
NOTION_API_TOKEN=your_notion_integration_token

# NotionのデータベースID
# データベースのURLから取得できます
# https://www.notion.so/your-username/[ここがデータベースID]?v=...
NOTION_DATABASE_ID=your_notion_database_id

# 注意: 対象のデータベースやページにインテグレーションが「共有」されていることを確認してください
# データベース/ページの右上の「...」メニュー → 「接続を追加」 → あなたのインテグレーションを選択
