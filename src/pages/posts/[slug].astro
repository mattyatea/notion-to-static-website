---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFormattedDatabase, getFormattedPage } from '@/lib/notion';
import { NotionBlocks } from '@/components/NotionBlock';
import TagChipLink from '@/components/TagChipLink.astro';
import type { FormattedPage } from '@/types/notion';

// 静的生成用のパスを生成する関数
export async function getStaticPaths() {
  try {
    const posts = await getFormattedDatabase();
    const postsWithBlocks = await Promise.all(
      posts.map(async (post) => {
        const fullPost = await getFormattedPage(post.id, true);
        return fullPost;
      })
    );

    return postsWithBlocks.map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
  } catch (error) {
    console.error('Error generating static paths:', error);
    return []; // エラーが発生した場合は空の配列を返す
  }
}

// Props から post を取得
const page = Astro.props.post as FormattedPage | null;

// タイトルを取得
const title = page?.title || '無題';
const summary = page?.summary || `${title}の記事ページです。`;
const canonicalPath = page?.slug ? `/posts/${page.slug}` : undefined;
const ogImage = page?.thumbnail?.url;
const articleStructuredData = page
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description: summary,
      image: ogImage,
      datePublished: page.date,
      dateModified: page.updatedAt || page.date,
      author: page.author?.name ? { '@type': 'Person', name: page.author.name } : undefined,
      inLanguage: 'ja-JP',
    }
  : undefined;

// エラーメッセージ（getStaticPaths が空を返すと post は undefined になる）
const error = !page ? 'ページが見つかりませんでした。' : null;
const publishDateIso = page?.date ? new Date(page.date).toISOString() : '';
const fallbackPublishDate = page?.date ? new Date(page.date).toLocaleDateString('ja-JP') : '';
---

<BaseLayout
  title={title}
  summary={summary}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  type="article"
  publishedTime={page?.date}
  modifiedTime={page?.updatedAt || page?.date}
  noindex={!page}
  structuredData={articleStructuredData}
>
  {
    error ? (
      <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-6">
        <p>
          <strong data-i18n="common.error">エラー:</strong>
          <span data-i18n="common.pageFetchFailed">ページの取得に失敗しました。</span>
        </p>
        <p class="text-sm" data-i18n="post.notFound">{error}</p>
        <a
          href="/posts"
          class="inline-block mt-3 text-blue-500 dark:text-blue-400 hover:underline"
          data-ga-event="view_item_list"
          data-ga-params={JSON.stringify({
            item_list_name: 'all_posts',
            source: 'post_detail_error',
          })}
        >
          <span data-i18n="post.backToList">← 一覧に戻る</span>
        </a>
      </div>
    ) : (
      <>
        <div class="mb-6">
          <a
            href="/posts"
            class="text-blue-500 dark:text-blue-400 hover:underline"
            data-ga-event="view_item_list"
            data-ga-params={JSON.stringify({
              item_list_name: 'all_posts',
              source: 'post_detail',
            })}
          >
            <span data-i18n="post.backToList">← 一覧に戻る</span>
          </a>
        </div>

        <article class="prose prose-lg dark:prose-invert max-w-3xl mx-auto">
          <header class="mb-8">
            <h1 class="text-3xl font-bold mb-3">{title}</h1>

            <div class="flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
              {
                page?.date && (
                  <time datetime={publishDateIso} data-publish-date={publishDateIso} data-i18n-date-label="post.publishedDate">
                    公開日: {fallbackPublishDate}
                  </time>
                )
              }
            </div>

            {page?.tags && page?.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-4">
                {page?.tags.map((tag) => (
                  <TagChipLink
                    tag={tag.name}
                    trackingSource="post_detail_tag"
                    context="post_detail"
                    class="text-gray-800 dark:text-gray-200"
                  />
                ))}
              </div>
            )}
          </header>

          <div class="notion-content">{page?.blocks && <NotionBlocks blocks={page?.blocks} />}</div>
        </article>
      </>
    )
  }
</BaseLayout>
