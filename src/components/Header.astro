---
const { siteName } = Astro.props;
---

<header class="py-6">
  <div class="flex justify-between items-center">
    <div>
      <a
        href="/"
        class="text-2xl font-bold hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        {siteName}
      </a>
    </div>
    <div class="flex items-center gap-6">
      <nav>
        <ul class="flex space-x-6">
          <li>
            <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
              <span data-i18n="nav.home">ホーム</span>
            </a>
          </li>
          <li>
            <a
              href="/posts"
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
              data-ga-event="view_item_list"
              data-ga-params={JSON.stringify({
                item_list_name: 'all_posts',
                source: 'header_nav',
              })}
            >
              <span data-i18n="nav.blog">ブログ</span>
            </a>
          </li>
        </ul>
      </nav>
      <label class="sr-only" for="language-select" data-i18n="nav.language">言語</label>
      <select
        id="language-select"
        class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 text-sm rounded-md px-2 py-1"
        aria-label="Language"
      >
        <option value="ja" data-i18n="nav.languageJapanese">日本語</option>
        <option value="en" data-i18n="nav.languageEnglish">English</option>
      </select>
    </div>
  </div>
</header>
