---
// Propsをexportして使用されていることを明示する
export interface Props {
  title: string;
  summary?: string;
  publishDate: Date;
  url: string;
  tags?: string[];
  coverImage?: string;
}

const { title, summary, publishDate, url, tags = [], coverImage } = Astro.props;

// 日付のフォーマット
const formattedDate = new Date(publishDate).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
  <a
    href={url}
    class="group block h-full hover:shadow-md transition-shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
  >
    {coverImage && (
      <img src={coverImage} alt={title} class="w-full h-48 object-cover" />
    )}

    <div class="p-6">
      <h3 class="text-xl font-semibold mb-2 transition-colors group-hover:text-blue-600 dark:group-hover:text-blue-400">
        {title}
      </h3>

      {summary && <p class="text-gray-600 dark:text-gray-400 mb-4">{summary}</p>}

      <div class="flex flex-wrap gap-2 mb-3">
        {
          tags.map((tag) => (
            <span
              class="inline-block bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs px-2 py-1 rounded"
            >
              {tag}
            </span>
          ))
        }
      </div>

      <div class="text-sm text-gray-500 dark:text-gray-400">
        {formattedDate}
      </div>
    </div>
  </a>
</article>
