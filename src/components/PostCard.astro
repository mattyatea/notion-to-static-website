---
import TagChipLink from '@/components/TagChipLink.astro';

// Propsをexportして使用されていることを明示する
export interface Props {
  title: string;
  summary?: string;
  publishDate: Date;
  url: string;
  tags?: string[];
  coverImage?: string;
  trackingSource?: string;
}

const { title, summary, publishDate, url, tags = [], coverImage, trackingSource = 'unknown' } = Astro.props;

// 日付のフォーマット
const formattedDate = new Date(publishDate).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden bg-white dark:bg-gray-900">
  <div class="group relative grid h-full grid-rows-[12rem_1fr] hover:shadow-md transition-shadow">
    <a
      href={url}
      aria-label={`${title}を読む`}
      class="absolute inset-0 z-10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
      data-ga-event="select_content"
      data-ga-params={JSON.stringify({
        content_type: 'article',
        item_id: url,
        item_name: title,
        source: trackingSource,
      })}
    ></a>
    <div class="relative h-48 overflow-hidden bg-gray-100 dark:bg-gray-800">
      {coverImage ? (
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        />
      ) : (
        <div class="grid h-full place-items-center bg-gradient-to-br from-gray-100 via-gray-50 to-gray-200 text-gray-500 dark:from-gray-800 dark:via-gray-800 dark:to-gray-700 dark:text-gray-400">
          <span class="text-xs tracking-[0.12em] uppercase">No Image</span>
        </div>
      )}
    </div>

    <div class="p-6 grid h-full gap-3 content-start">
      <h3 class="relative z-20 text-xl font-semibold mb-2 transition-colors group-hover:text-blue-600 dark:group-hover:text-blue-400">
        {title}
      </h3>

      {summary && <p class="text-gray-600 dark:text-gray-400">{summary}</p>}

      <div class="relative z-20 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <TagChipLink tag={tag} trackingSource={trackingSource} context="post_card" />
          ))
        }
      </div>

      <div class="mt-auto text-sm text-gray-500 dark:text-gray-400">
        {formattedDate}
      </div>
    </div>
  </div>
</article>
