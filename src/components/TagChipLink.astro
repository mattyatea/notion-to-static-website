---
export interface Props {
  tag: string;
  trackingSource?: string;
  context?: string;
  class?: string;
}

const { tag, trackingSource = 'unknown', context = 'tag_link', class: className = '' } = Astro.props;
const href = `/tags/${encodeURIComponent(tag)}`;
const classes = `inline-block bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs px-2 py-1 rounded hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900/40 dark:hover:text-blue-300 transition-colors ${className}`.trim();
---

<a
  href={href}
  class={classes}
  data-ga-event="view_item_list"
  data-ga-params={JSON.stringify({
    item_list_name: `tag_${tag}`,
    source: trackingSource,
    context,
  })}
>
  {tag}
</a>
