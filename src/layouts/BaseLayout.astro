---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { DEFAULT_LOCALE, I18N_MESSAGES, LOCALE_STORAGE_KEY, SUPPORTED_LOCALES } from '@/lib/i18n';
const siteName = process.env.SITE_NAME ?? 'notion to static page';
const siteUrl = import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, '');
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();

const {
  title = siteName,
  summary,
  canonicalPath,
  canonicalUrl,
  ogImage,
  noindex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  structuredData,
} = Astro.props;

const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const pageSummary = summary?.trim() || `${siteName}の公式サイトです。`;

const resolvedCanonicalUrl =
  canonicalUrl ?? (canonicalPath && siteUrl ? new URL(canonicalPath, siteUrl).toString() : undefined);

const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const twitterCardType = ogImage ? 'summary_large_image' : 'summary';
---

<!doctype html>
<html lang={DEFAULT_LOCALE}>
  <head prefix="og: http://ogp.me/ns#">
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="view-transition" content="same-origin" />
    <meta name="description" content={pageSummary} />
    <meta name="robots" content={robotsContent} />
    {resolvedCanonicalUrl && <link rel="canonical" href={resolvedCanonicalUrl} />}
    <meta property="og:description" content={pageSummary} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    {resolvedCanonicalUrl && <meta property="og:url" content={resolvedCanonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={twitterCardType} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageSummary} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <title>{pageTitle}</title>
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    )}
    {gaMeasurementId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>}
    {gaMeasurementId && (
      <script is:inline>
        {`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}

gtag('js', new Date());
gtag('config', '${gaMeasurementId}', {
  anonymize_ip: true,
  send_page_view: false
});

const parseAnalyticsParams = (rawParams) => {
  if (!rawParams) {
    return {};
  }

  try {
    return JSON.parse(rawParams);
  } catch {
    return {};
  }
};

const trackPageView = () => {
  const pagePath = window.location.pathname + window.location.search;

  if (window.__gaLastTrackedPath === pagePath) {
    return;
  }

  window.__gaLastTrackedPath = pagePath;
  gtag('event', 'page_view', {
    page_title: document.title,
    page_location: window.location.href,
    page_path: pagePath
  });
};

if (!window.__gaClickTrackingAttached) {
  document.addEventListener('click', (event) => {
    const eventTarget = event.target;
    if (!(eventTarget instanceof Element)) {
      return;
    }

    const trackingElement = eventTarget.closest('[data-ga-event]');
    if (!trackingElement) {
      return;
    }

    const eventName = trackingElement.getAttribute('data-ga-event');
    if (!eventName) {
      return;
    }

    const eventParams = parseAnalyticsParams(trackingElement.getAttribute('data-ga-params'));
    gtag('event', eventName, eventParams);
  });

  window.__gaClickTrackingAttached = true;
}

if (!window.__gaPageViewTrackingAttached) {
  trackPageView();
  document.addEventListener('astro:page-load', trackPageView);
  window.__gaPageViewTrackingAttached = true;
}`}
      </script>
    )}
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
            document.documentElement.classList.add('dark');
            return;
          }
          document.documentElement.classList.remove('dark');
        } catch {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <script
      is:inline
      define:vars={{
        i18nMessages: I18N_MESSAGES,
        i18nSupportedLocales: SUPPORTED_LOCALES,
        i18nDefaultLocale: DEFAULT_LOCALE,
        i18nLocaleStorageKey: LOCALE_STORAGE_KEY,
      }}
    >
      (() => {
const messages = i18nMessages;
const supportedLocales = i18nSupportedLocales;
const defaultLocale = i18nDefaultLocale;
const localeStorageKey = i18nLocaleStorageKey;

const isSupportedLocale = (value) => supportedLocales.includes(value);

const normalizeLocale = (rawLocale) => {
  if (!rawLocale) {
    return defaultLocale;
  }

  const normalized = String(rawLocale).toLowerCase().split('-')[0];
  return isSupportedLocale(normalized) ? normalized : defaultLocale;
};

const loadPreferredLocale = () => {
  try {
    const saved = localStorage.getItem(localeStorageKey);
    if (saved) {
      return normalizeLocale(saved);
    }
  } catch {
    // ignore localStorage read failure
  }

  return normalizeLocale(navigator.language);
};

const savePreferredLocale = (locale) => {
  try {
    localStorage.setItem(localeStorageKey, locale);
  } catch {
    // ignore localStorage write failure
  }
};

const resolveMessage = (locale, key, vars) => {
  const table = messages[locale] || messages[defaultLocale] || {};
  const fallbackTable = messages[defaultLocale] || {};
  const raw = table[key] || fallbackTable[key] || key;

  return raw.replace(/\{(\w+)\}/g, (_, token) => {
    if (!vars || vars[token] == null) {
      return '';
    }

    return String(vars[token]);
  });
};

const parseVars = (rawVars) => {
  if (!rawVars) {
    return {};
  }

  try {
    const parsed = JSON.parse(rawVars);
    return parsed && typeof parsed === 'object' ? parsed : {};
  } catch {
    return {};
  }
};

const localizeElementText = (locale) => {
  const targets = document.querySelectorAll('[data-i18n]');
  for (const target of targets) {
    if (!(target instanceof HTMLElement)) {
      continue;
    }

    const key = target.dataset.i18n;
    if (!key) {
      continue;
    }

    const vars = parseVars(target.dataset.i18nVars);
    target.textContent = resolveMessage(locale, key, vars);
  }
};

const localizeAriaLabels = (locale) => {
  const targets = document.querySelectorAll('[data-i18n-aria-label]');
  for (const target of targets) {
    if (!(target instanceof HTMLElement)) {
      continue;
    }

    const key = target.dataset.i18nAriaLabel;
    if (!key) {
      continue;
    }

    const vars = parseVars(target.dataset.i18nAriaLabelVars);
    target.setAttribute('aria-label', resolveMessage(locale, key, vars));
  }
};

const localizeTitleAttributes = (locale) => {
  const targets = document.querySelectorAll('[data-i18n-title]');
  for (const target of targets) {
    if (!(target instanceof HTMLElement)) {
      continue;
    }

    const key = target.dataset.i18nTitle;
    if (!key) {
      continue;
    }

    const vars = parseVars(target.dataset.i18nTitleVars);
    target.title = resolveMessage(locale, key, vars);
  }
};

const localizeInputOptions = (locale) => {
  const targets = document.querySelectorAll('option[data-i18n], [data-i18n-value]');
  for (const target of targets) {
    if (!(target instanceof HTMLElement)) {
      continue;
    }

    const key = target.dataset.i18n || target.dataset.i18nValue;
    if (!key) {
      continue;
    }

    target.textContent = resolveMessage(locale, key, {});
  }
};

const localizePublishDates = (locale) => {
  const targets = document.querySelectorAll('[data-publish-date]');
  for (const target of targets) {
    if (!(target instanceof HTMLElement)) {
      continue;
    }

    const rawDate = target.dataset.publishDate;
    if (!rawDate) {
      continue;
    }

    const date = new Date(rawDate);
    if (Number.isNaN(date.getTime())) {
      continue;
    }

    const localeTag = locale === 'ja' ? 'ja-JP' : 'en-US';
    const formattedDate = date.toLocaleDateString(localeTag, {
      year: 'numeric',
      month: locale === 'ja' ? 'long' : 'short',
      day: 'numeric',
    });

    const key = target.dataset.i18nDateLabel;
    if (key) {
      target.textContent = resolveMessage(locale, key, { date: formattedDate });
      continue;
    }

    target.textContent = formattedDate;
  }
};

const applyLocale = (rawLocale) => {
  const locale = normalizeLocale(rawLocale);

  document.documentElement.lang = locale;
  if (document.body) {
    document.body.dataset.locale = locale;
  }

  localizeElementText(locale);
  localizeAriaLabels(locale);
  localizeTitleAttributes(locale);
  localizeInputOptions(locale);
  localizePublishDates(locale);

  const selector = document.getElementById('language-select');
  if (selector instanceof HTMLSelectElement && selector.value !== locale) {
    selector.value = locale;
  }

  return locale;
};

const bootstrapI18n = () => {
  const locale = loadPreferredLocale();
  const appliedLocale = applyLocale(locale);
  savePreferredLocale(appliedLocale);

  const selector = document.getElementById('language-select');
  if (selector instanceof HTMLSelectElement && !selector.dataset.i18nBound) {
    selector.dataset.i18nBound = 'true';
    selector.value = appliedLocale;
    selector.addEventListener('change', (event) => {
      const nextValue = event.target instanceof HTMLSelectElement ? event.target.value : defaultLocale;
      const nextLocale = applyLocale(nextValue);
      savePreferredLocale(nextLocale);
    });
  }
};

if (!window.__localeInitAttached) {
  document.addEventListener('DOMContentLoaded', bootstrapI18n, { once: true });
  document.addEventListener('astro:page-load', bootstrapI18n);
  window.__localeInitAttached = true;
}
})();
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="transition-header">
        <Header siteName={siteName} />
      </div>

      <main class="py-8 page-transition-surface">
        <slot />
      </main>

      <div class="transition-footer">
        <Footer siteName={siteName} />
      </div>
    </div>
  </body>
</html>
